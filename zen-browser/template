# Template file for 'zen-browser'
pkgname=zen-browser
version=1.19.10b
revision=1
archs="x86_64 aarch64"
build_style=fetch
hostmakedepends="tar xz"
depends="desktop-file-utils hicolor-icon-theme libnotify libavcodec xdg-utils nss nspr"
short_desc="Welcome to a calmer internet"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="MPL-2.0"
homepage="https://www.zen-browser.app/"

case "${XBPS_TARGET_MACHINE}" in
x86_64*)
    _upstream_arch=x86_64
    _checksum=87978f0854fc279191b4f95a41bdb0c5b7df6f6b6c1d986c97ef75915cd6686c
    ;;
aarch64*)
    _upstream_arch=aarch64
    _checksum=78d45f75527146b59f49e806d220b7872091443965b727132703edd110661988
    ;;
*) broken="No distfiles available for this target" ;;
esac

distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-${_upstream_arch}.tar.xz
 https://raw.githubusercontent.com/zen-browser/desktop/refs/heads/dev/LICENSE>LICENSE"
checksum="afba63e56a638d0c6f2dffcc16e59c20055c06ab2df95270daf70a463028b973
 c76f740d1521b9bed9ca7a04ad526c310493c62621b1341d623b431736533b30"

do_install() {
    vmkdir opt/zen-browser
    vmkdir usr/bin

    # 1. The Bypass: Extract the binary package directly into the destination folder
    # We use -xf (quiet) instead of -xvf so it doesn't spam the GitHub Actions logs
    tar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/zen.linux-${_upstream_arch}.tar.xz -C ${DESTDIR}/opt/zen-browser --strip-components=1

    # 2. Symlink the executable
    ln -sf /opt/zen-browser/zen ${DESTDIR}/usr/bin/zen

    # 3. Install desktop entries and policies
    if [ -f "${FILESDIR}/zen.desktop" ]; then
        vinstall ${FILESDIR}/zen.desktop 0644 usr/share/applications/
    fi
    
    if [ -f "${FILESDIR}/policies.json" ]; then
        vmkdir opt/zen-browser/distribution
        vinstall ${FILESDIR}/policies.json 0644 opt/zen-browser/distribution/
    fi

    # 4. Install icons
    local _icon_path="${DESTDIR}/opt/zen-browser/browser/chrome/icons/default"
    if [ -d "$_icon_path" ]; then
        vinstall ${_icon_path}/default48.png 0644 usr/share/pixmaps zen.png
        for size in 16 32 48 64 128; do
            vmkdir usr/share/icons/hicolor/${size}x${size}/apps
            vinstall ${_icon_path}/default${size}.png 0644 usr/share/icons/hicolor/${size}x${size}/apps zen.png
        done
    fi

    # 5. Link system dictionaries (for spellcheck)
    ln -sf /usr/share/hunspell ${DESTDIR}/opt/zen-browser/dictionaries
    ln -sf /usr/share/hyphen ${DESTDIR}/opt/zen-browser/hyphenation

    # 6. Force Zen to use Void's native NSS/NSPR libraries and certificates
    for f in libnspr4.so libnss3.so libnssutil3.so libplc4.so \
             libplds4.so libsmime3.so libssl3.so libnssckbi.so; do
        if [ -f "${DESTDIR}/opt/zen-browser/${f}" ]; then
            rm -f ${DESTDIR}/opt/zen-browser/${f}
            ln -sf /usr/lib/${f} ${DESTDIR}/opt/zen-browser/${f}
        fi
    done
    
    # 7. Install License directly from the source distribution directory
    vlicense ${XBPS_SRCDISTDIR}/${pkgname}-${version}/LICENSE
}
