# Template file for 'zed'
pkgname=zed
version=1.0.0
revision=1
archs="x86_64* aarch64*"
build_style=cargo
make_cmd="env -u LIBGIT2_NO_VENDOR cargo"
make_install_args="--path crates/zed"
make_check_args="-- --test-threads 1"

hostmakedepends="
  clang18
  cmake
  gettext
  mold
  pkg-config
  protobuf
"
makedepends="
  alsa-lib-devel
  fontconfig-devel
  glib-devel
  libX11-devel
  libxcb-devel
  libxkbcommon-devel
  libzstd-devel
  openssl-devel
  sqlite-devel
  vulkan-loader
  wayland-devel
"
depends="git"
checkdepends="noto-fonts-ttf"
short_desc="High-performance, multiplayer code editor from the creators of Atom"
maintainer="Quietcraft <https://github.com/Ackerman-00>"
license="GPL-3.0-or-later, Apache-2.0, AGPL-3.0-or-later"
homepage="https://zed.dev"
changelog="https://github.com/zed-industries/zed/releases"
distfiles="https://github.com/zed-industries/zed/archive/refs/tags/v${version}.tar.gz"
checksum=9e1547910d9840295e562fe383182abf633c514e27cc312ace369c2220192162

pre_build() {
    # 1. Tell the extension registry and credential manager this is a stable build
    # Without this, Zed cannot authenticate or download extensions.
    printf "stable" > crates/zed/RELEASE_CHANNEL

    # 2. Stable check
    export ZED_UPDATE_EXPLANATION="Updates are handled by Void Nexus"
    export RELEASE_VERSION="${version}"
    export CARGO_PROFILE_RELEASE_DEBUG=0
    export CARGO_PROFILE_RELEASE_STRIP="symbols"

    # Force the mold linker
    export RUSTFLAGS="$RUSTFLAGS -C link-arg=-fuse-ld=mold"
}

pre_install() {
    export ZED_UPDATE_EXPLANATION="Updates are handled by Void Nexus"
    export RELEASE_VERSION="${version}"
    export CARGO_PROFILE_RELEASE_DEBUG=0
    export CARGO_PROFILE_RELEASE_STRIP="symbols"
    export RUSTFLAGS="$RUSTFLAGS -C link-arg=-fuse-ld=mold"
}

post_install() {
    vlicense ${wrksrc}/LICENSE-AGPL

    # 1. Drop the icon into the universal pixmaps folder
    vinstall ${wrksrc}/crates/zed/resources/app-icon.png 644 usr/share/pixmaps zed.png

    # 2. Desktop file
    vmkdir usr/share/applications
    cat > "${DESTDIR}/usr/share/applications/zed.desktop" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Zed
GenericName=Text Editor
Comment=A high-performance, multiplayer code editor.
Exec=zed %U
Icon=/usr/share/pixmaps/zed.png
Terminal=false
StartupNotify=true
StartupWMClass=dev.zed.Zed
Categories=Development;Utility;TextEditor;
EOF
}
