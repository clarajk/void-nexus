# Template file for 'noctalia-shell'
pkgname=noctalia-shell
version=4.7.7
revision=1
hostmakedepends=""
maintainer="Ackerman <https://github.com/Ackerman-00>"

# Dependency List
depends="noctalia-qs matugen qt6-plugin-tls-openssl power-profiles-daemon upower 
 fonts-roboto-ttf brightnessctl ddcutil cliphist wl-clipboard playerctl libnotify 
 qt6-qt5compat qt6-multimedia qt6-svg qt6-wayland qt6-tools libxcb"

short_desc="A sleek and minimal desktop shell thoughtfully crafted for Wayland, built with Quickshell."
homepage="https://github.com/noctalia-dev/noctalia-shell"
license="MIT"

distfiles="https://github.com/noctalia-dev/noctalia-shell/archive/refs/tags/v${version}.tar.gz"
checksum=1189099030b24097d2a351015d2f0290f2ff03dfc928dc4c4191cbace2b7b2ad

build() {
    return 0
}

do_install() {
    # Install globally into standard xdg system path
    mkdir -p "${DESTDIR}/etc/xdg/quickshell/noctalia-shell"
    cp -r "${wrksrc}/"* "${DESTDIR}/etc/xdg/quickshell/noctalia-shell/"

    # Provide it in /usr/share per standard packaging guidelines
    mkdir -p "${DESTDIR}/usr/share/noctalia-shell"
    cp -r "${wrksrc}/"* "${DESTDIR}/usr/share/noctalia-shell/"
}

post_install() {
    echo "========================================================================="
    echo "Noctalia Shell installed successfully!"
    echo "To use it, copy the config to your user directory:"
    echo "  mkdir -p ~/.config/quickshell"
    echo "  cp -r /usr/share/noctalia-shell/* ~/.config/quickshell/"
    echo "========================================================================="
}
